# Copy the lines you need into ~/.hermes/.env so the gateway exposes the HTTP API
# that hermes-web-ui (BFF) calls at UPSTREAM (default http://127.0.0.1:8642).
#
# See also: hermes-web-ui repo .env.example (PORT, UPSTREAM, HERMES_BIN).

API_SERVER_ENABLED=true
# Optional: if set, hermes-web-ui reads it from this file and proxies with Authorization: Bearer.

# API_SERVER_KEY=change-me
# API_SERVER_PORT=8642
# API_SERVER_HOST=127.0.0.1
